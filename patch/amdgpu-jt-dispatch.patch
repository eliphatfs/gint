--- a/llvm/lib/Target/AMDGPU/AMDGPUTargetObjectFile.cpp	2026-02-24 07:35:28.000000000 +0000
+++ b/llvm/lib/Target/AMDGPU/AMDGPUTargetObjectFile.cpp	2026-07-02 18:07:58.069871530 +0000
@@ -26,6 +26,19 @@
   return TargetLoweringObjectFileELF::SelectSectionForGlobal(GO, Kind, TM);
 }
 
+MCSection *AMDGPUTargetObjectFile::getSectionForJumpTable(
+    const Function &F, const TargetMachine &TM,
+    const MachineJumpTableEntry *JTE) const {
+  // Emit jump tables into the .text section (same section as the function
+  // body) rather than .rodata. AMDGPU uses EK_LabelDifference32 jump-table
+  // entries (`.long BB - JT`); if the table lands in a different section
+  // from the code (here .rodata vs .text), the cross-section label difference
+  // is not resolvable at assembly time and the entries get emitted as 0,
+ // corrupting the dispatch. Keeping the table in .text makes the
+  // `BB - JT` difference a same-section offset that resolves correctly.
+  return TextSection;
+}
