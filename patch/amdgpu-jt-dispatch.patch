diff -ruN a/llvm/lib/Target/AMDGPU/SIExpandJTDispatch.cpp b/llvm/lib/Target/AMDGPU/SIExpandJTDispatch.cpp
--- a/llvm/lib/Target/AMDGPU/SIExpandJTDispatch.cpp	1970-01-01 00:00:00.000000000 +0000
+++ b/llvm/lib/Target/AMDGPU/SIExpandJTDispatch.cpp	2026-07-02 18:36:05.697074628 +0000
@@ -0,0 +1,254 @@
+//===-- SIExpandJTDispatch.cpp - Expand SI_BR_JT jump-table dispatch ------===//
+//
+// Part of the LLVM Project, under the Apache License v2.0 with LLVM Exceptions.
+// See https://llvm.org/LICENSE.txt for license information.
+// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
+//
+//===----------------------------------------------------------------------===//
+//
+// This pass expands the SI_BR_JT pseudo (produced by LowerBR_JT for a dense
+// switch dispatched via a jump table) into the real instruction sequence:
+//
+//   s_getpc_b64    s[BaseLo:BaseHi]            ; PC of next instr
+//   s_add_co_u32   BaseLo, BaseLo, jt@rel32@lo+4
+//   s_add_co_ci_u32 BaseHi, BaseHi, jt@rel32@hi+12  -> table base (64-bit)
+//   s_lshl_b32     ByteOff32, IdxLo, 3       ; index*8 = byte offset
+//   s_load_dwordx2 Target, Base64, ByteOff32 ; load jump-table entry
+//   s_setpc_b64    Target                     ; O(1) dispatch
+//
+// It runs BEFORE register allocation (in addInstSelector, right after ISel)
+// so the freshly-created virtual registers are allocated normally. We use
+// distinct 32-bit vregs (BaseLo/BaseHi) for the two halves of the rel32 add
+// and REG_SEQUENCE them into a 64-bit Base64, because defining sub0/sub1 of a
+// single vreg before RA trips LiveVariables' single-definition assumption.
+//
+// The +4/+12 PC-rel fixups are applied in AMDGPUMCInstLower at MCExpr level
+// because JTI operands have no offset field.
+//
+//===----------------------------------------------------------------------===//
+
+#include "AMDGPU.h"
+#include "GCNSubtarget.h"
+#include "MCTargetDesc/AMDGPUMCTargetDesc.h"
+#include "SIInstrInfo.h"
+#include "llvm/CodeGen/MachineFunctionPass.h"
+#include "llvm/CodeGen/MachineInstrBuilder.h"
+#include "llvm/CodeGen/MachineOperand.h"
+#include "llvm/CodeGen/MachineRegisterInfo.h"
+#include "llvm/MC/MCContext.h"
+#include "llvm/MC/MCExpr.h"
+#include "llvm/MC/MCSymbol.h"
+#include "llvm/InitializePasses.h"
+
+using namespace llvm;
+
+// Forward declaration: INITIALIZE_PASS below generates the definition, but
+// the legacy pass constructor (which precedes it) references it.
+namespace llvm {
+void initializeSIExpandJTDispatchPass(PassRegistry &);
+}
+
+#define DEBUG_TYPE "si-expand-jt-dispatch"
+#define PASS_NAME "SI Expand Jump-Table Dispatch"
+
+namespace {
+
+/// Core expansion logic, shared by the legacy and NewPM entry points.
+static bool expandJTDispatch(MachineFunction &MF, const SIInstrInfo *TII) {
+  MachineRegisterInfo &MRI = MF.getRegInfo();
+  bool Changed = false;
+
+  for (MachineBasicBlock &MBB : MF) {
+    for (MachineInstr &MI : make_early_inc_range(MBB)) {
+      if (MI.getOpcode() != AMDGPU::SI_BR_JT)
+        continue;
+
+      DebugLoc DL = MI.getDebugLoc();
+      MachineOperand JTOp = MI.getOperand(0);   // jump-table symbol (JTI)
+      Register IndexReg = MI.getOperand(1).getReg();
+
+      // Distinct virtual registers (no sub0/sub1 defs of a single vreg before
+      // RA: LiveVariables requires at most one def per vreg).
+      //   PCReg       : 64-bit program counter from s_getpc (single 64-bit def)
+      //   BaseLo/BaseHi: 32-bit halves of the table base (PC.sub + JTI offset)
+      //   Base64      : REG_SEQUENCE composing BaseLo:BaseHi into a 64-bit SGPR
+      //   ByteOff32   : 32-bit byte offset (index<<2) for the SMRD soffset.
+      //                Jump-table entries are 4 bytes each (EK_LabelDifference32:
+      //                each entry is `.long BB - JT`, a 32-bit *relative* offset
+      //                from the table base), so index<<2 selects the entry.
+      //   EntryOff32  : the loaded 4-byte relative offset (BB - JT)
+      //   SignExt32   : arithmetic shift-right by 31 of EntryOff32, i.e. the
+      //                sign-extension of the (possibly negative) 32-bit offset
+      //                to its high half (0 for >=0, -1 for <0).
+      //   TgtLo/TgtHi : absolute target address = table base + sign-extended off
+      //   Tgt64       : REG_SEQUENCE composing TgtLo:TgtHi into a 64-bit SGPR
+      Register PCReg    = MRI.createVirtualRegister(&AMDGPU::SReg_64RegClass);
+      Register BaseLo  = MRI.createVirtualRegister(&AMDGPU::SReg_32_XM0RegClass);
+      Register BaseHi  = MRI.createVirtualRegister(&AMDGPU::SReg_32_XM0RegClass);
+      Register Base64  = MRI.createVirtualRegister(&AMDGPU::SReg_64RegClass);
+      Register ByteOff32 = MRI.createVirtualRegister(&AMDGPU::SReg_32_XM0RegClass);
+      Register EntryOff32 = MRI.createVirtualRegister(&AMDGPU::SReg_32_XM0RegClass);
+      Register SignExt32 = MRI.createVirtualRegister(&AMDGPU::SReg_32_XM0RegClass);
+      Register TgtLo  = MRI.createVirtualRegister(&AMDGPU::SReg_32_XM0RegClass);
+      Register TgtHi  = MRI.createVirtualRegister(&AMDGPU::SReg_32_XM0RegClass);
+      Register Tgt64  = MRI.createVirtualRegister(&AMDGPU::SReg_64RegClass);
+
+      auto InsertPt = MI.getIterator();
+
+      // Compute the jump-table base address (Base64 = JTI symbol address).
+      //
+      // We use the same PC-relative mechanism as SIInstrInfo::insertIndirectBranch
+      // (the long-branch path): s_getpc_b64 then s_add_u32 / s_addc_u32 with a
+      // *symbol* operand (OffsetSym, MO_FAR_BRANCH_OFFSET) whose variable value
+      // is `(JTI - PostGetPC)`, where PostGetPC is a label attached to the
+      // s_getpc instruction. s_getpc returns the address of PostGetPC, so
+      //   s8 = PostGetPC + (JTI - PostGetPC) = JTI
+      // with no dependence on the s_add position. This is essential because the
+      // hazard recognizer can insert s_wait_alu between s_getpc and s_add; a
+      // rel32@lo/@hi fixup keyed to the s_add's own address would then be off by
+      // the inserted instruction size and send s_setpc into the wrong place.
+      // Keying the offset to the s_getpc's post-instruction label makes the
+      // computation immune to whatever the scheduler/hazard recognizer inserts
+      // in between. (S_ADD_PC_I64 would do this in one instruction but it is
+      // gfx1250+ only; gfx1201 lacks it.)
+      MachineInstr *GetPC =
+          BuildMI(MBB, InsertPt, DL, TII->get(AMDGPU::S_GETPC_B64), PCReg);
+      // Keep a live reference to the jump table so BranchFolding's liveness
+      // scan (BranchFolding.cpp ~line 263: it removes any jump table with no
+      // surviving MO_JumpTableIndex operand) keeps the table. SI_BR_JT used to
+      // carry that operand; once we expand it away the JTI operand disappears
+      // and BranchFolding would RemoveJumpTable() the table, zeroing all
+      // entries and corrupting dispatch. We attach a JTI operand to the
+      // s_getpc as a side reference (the assembler ignores it; it exists only
+      // to keep the table live through control-flow optimization).
+      GetPC->addOperand(MF,
+                        MachineOperand::CreateJTI(JTOp.getIndex(),
+                                                  JTOp.getTargetFlags()));
+      MCSymbol *PostGetPCLabel =
+          MF.getContext().createTempSymbol("post_getpc", /*AlwaysAddSuffix=*/true);
+      GetPC->setPostInstrSymbol(MF, PostGetPCLabel);
+      MCSymbol *JTISym = MF.getJTISymbol(JTOp.getIndex(), MF.getContext());
+      const MCExpr *OffsetExpr = MCBinaryExpr::createSub(
+          MCSymbolRefExpr::create(JTISym, MF.getContext()),
+          MCSymbolRefExpr::create(PostGetPCLabel, MF.getContext()),
+          MF.getContext());
+      MCSymbol *OffsetSym =
+          MF.getContext().createTempSymbol("jt_offset", /*AlwaysAddSuffix=*/true);
+      OffsetSym->setVariableValue(OffsetExpr);
+
+      // s_add_u32 BaseLo, PCReg.sub0, OffsetSym(lo)  — carry-out -> SCC.
+      // Split the 64-bit (JTI - PostGetPC) offset into lo/hi via two MCSymbols
+      // that reference it (mirrors insertIndirectBranch's OffsetLo/OffsetHi).
+      MCSymbol *OffsetLo =
+          MF.getContext().createTempSymbol("jt_off_lo", /*AlwaysAddSuffix=*/true);
+      MCSymbol *OffsetHi =
+          MF.getContext().createTempSymbol("jt_off_hi", /*AlwaysAddSuffix=*/true);
+      OffsetLo->setVariableValue(
+          MCBinaryExpr::createAnd(OffsetExpr,
+                                  MCConstantExpr::create(0xFFFFFFFFu, MF.getContext()),
+                                  MF.getContext()));
+      OffsetHi->setVariableValue(
+          MCBinaryExpr::createAShr(OffsetExpr,
+                                   MCConstantExpr::create(32, MF.getContext()),
+                                   MF.getContext()));
+      BuildMI(MBB, InsertPt, DL, TII->get(AMDGPU::S_ADD_U32), BaseLo)
+          .addReg(PCReg, 0, AMDGPU::sub0)
+          .addSym(OffsetLo, SIInstrInfo::MO_FAR_BRANCH_OFFSET);
+      BuildMI(MBB, InsertPt, DL, TII->get(AMDGPU::S_ADDC_U32), BaseHi)
+          .addReg(PCReg, 0, AMDGPU::sub1)
+          .addSym(OffsetHi, SIInstrInfo::MO_FAR_BRANCH_OFFSET);
+
+      // Compose the two halves into a 64-bit SGPR for the SMRD base.
+      BuildMI(MBB, InsertPt, DL, TII->get(AMDGPU::REG_SEQUENCE), Base64)
+          .addReg(BaseLo)
+          .addImm(AMDGPU::sub0)
+          .addReg(BaseHi)
+          .addImm(AMDGPU::sub1);
+
+      // ByteOff32 = (IndexReg.sub0) << 2   (element index -> byte offset, *4:
+      // each jump-table entry is 4 bytes — EK_LabelDifference32, `.long BB-JT`).
+      BuildMI(MBB, InsertPt, DL, TII->get(AMDGPU::S_LSHL_B32), ByteOff32)
+          .addReg(IndexReg, 0, AMDGPU::sub0)
+          .addImm(2);
+
+      // s_load_dword EntryOff32, Base64, ByteOff32 (soffset), 0 imm, 0 cpol.
+      // Loads the 4-byte relative offset (BB - JT) stored in the entry.
+      BuildMI(MBB, InsertPt, DL, TII->get(AMDGPU::S_LOAD_DWORD_SGPR_IMM),
+              EntryOff32)
+          .addReg(Base64)
+          .addReg(ByteOff32)
+          .addImm(0)    // imm offset
+          .addImm(0);   // cpol (cache policy: none)
+
+      // Sign-extend the 32-bit relative offset to 64 bits (BB may precede JT,
+      // giving a negative BB-JT offset): high half = ashr(entry, 31).
+      BuildMI(MBB, InsertPt, DL, TII->get(AMDGPU::S_ASHR_I32), SignExt32)
+          .addReg(EntryOff32)
+          .addImm(31);
+
+      // Absolute target = table base + sign-extended offset (64-bit add via
+      // the s_add/s_addc carry chain).
+      BuildMI(MBB, InsertPt, DL, TII->get(AMDGPU::S_ADD_U32), TgtLo)
+          .addReg(BaseLo)
+          .addReg(EntryOff32);
+      BuildMI(MBB, InsertPt, DL, TII->get(AMDGPU::S_ADDC_U32), TgtHi)
+          .addReg(BaseHi)
+          .addReg(SignExt32);
+
+      // Compose the absolute target into a 64-bit SGPR for s_setpc.
+      BuildMI(MBB, InsertPt, DL, TII->get(AMDGPU::REG_SEQUENCE), Tgt64)
+          .addReg(TgtLo)
+          .addImm(AMDGPU::sub0)
+          .addReg(TgtHi)
+          .addImm(AMDGPU::sub1);
+
+      // s_setpc_b64 Tgt64  (O(1) dispatch to the selected instruction block)
+      BuildMI(MBB, InsertPt, DL, TII->get(AMDGPU::S_SETPC_B64)).addReg(Tgt64);
+      MI.eraseFromParent();
+      Changed = true;
+    }
+  }
+
+  return Changed;
+}
+
+class SIExpandJTDispatch : public MachineFunctionPass {
+public:
+  static char ID;
+
+  SIExpandJTDispatch() : MachineFunctionPass(ID) {
+    initializeSIExpandJTDispatchPass(*PassRegistry::getPassRegistry());
+  }
+
+  bool runOnMachineFunction(MachineFunction &MF) override;
+
+  StringRef getPassName() const override { return PASS_NAME; }
+
+  void getAnalysisUsage(AnalysisUsage &AU) const override {
+    AU.setPreservesCFG();
+    MachineFunctionPass::getAnalysisUsage(AU);
+  }
+};
+
+} // End anonymous namespace
+
+char SIExpandJTDispatch::ID = 0;
+INITIALIZE_PASS(SIExpandJTDispatch, DEBUG_TYPE, PASS_NAME, false, false)
+
+FunctionPass *llvm::createSIExpandJTDispatchPass() {
+  return new SIExpandJTDispatch();
+}
+
+PreservedAnalyses llvm::SIExpandJTDispatchPass::run(MachineFunction &MF,
+                                            MachineFunctionAnalysisManager &) {
+  const GCNSubtarget &ST = MF.getSubtarget<GCNSubtarget>();
+  bool Changed = expandJTDispatch(MF, ST.getInstrInfo());
+  if (!Changed)
+    return PreservedAnalyses::all();
+  return getMachineFunctionPassPreservedAnalyses().preserveSet<CFGAnalyses>();
+}
+
+bool SIExpandJTDispatch::runOnMachineFunction(MachineFunction &MF) {
+  const GCNSubtarget &ST = MF.getSubtarget<GCNSubtarget>();
+  return expandJTDispatch(MF, ST.getInstrInfo());
+}
