diff -ruN a/llvm/lib/Target/AMDGPU/AMDGPUMCInstLower.cpp b/llvm/lib/Target/AMDGPU/AMDGPUMCInstLower.cpp
--- a/llvm/lib/Target/AMDGPU/AMDGPUMCInstLower.cpp	2026-02-24 07:35:28.000000000 +0000
+++ b/llvm/lib/Target/AMDGPU/AMDGPUMCInstLower.cpp	2026-07-02 16:39:09.541134575 +0000
@@ -101,6 +101,50 @@
     MCOp = MCOperand::createExpr(Expr);
     return true;
   }
+  case MachineOperand::MO_BlockAddress: {
+    // Materialize an in-function block-address placeholder as a reference to
+    // the basic block's label symbol, with the same relocation specifier
+    // mechanism used for global addresses (e.g. MO_REL32_LO/HI for the
+    // s_getpc + s_add(rel32) sequence emitted by LowerBlockAddress).
+    const BlockAddress *BA = MO.getBlockAddress();
+    MCSymbol *Sym = AP.GetBlockAddressSymbol(BA);
+    const MCExpr *Expr =
+        MCSymbolRefExpr::create(Sym, getSpecifier(MO.getTargetFlags()), Ctx);
+    int64_t Offset = MO.getOffset();
+    if (Offset != 0) {
+      Expr = MCBinaryExpr::createAdd(Expr,
+                                     MCConstantExpr::create(Offset, Ctx), Ctx);
+    }
+    MCOp = MCOperand::createExpr(Expr);
+    return true;
+  }
+  case MachineOperand::MO_JumpTableIndex: {
+    // The jump-table symbol for the dispatch table (emitted by SI_BR_JT).
+    // Uses the same relocation-specifier mechanism as globals/block-addresses
+    // so the s_getpc + s_add(rel32) sequence resolves to the table base.
+    // JTI operands have no offset field, so the PC-rel +4 fixup (the symbol is
+    // encoded 4 bytes after the start of the s_add_u32/s_add_u64 instruction)
+    // is applied here directly as a constant add, keyed off the rel32 target
+    // flag. MO_REL32 (single 64-bit add) gets +4; the lo/hi split forms each
+    // get their own fixed offset.
+    MCSymbol *Sym = AP.GetJTISymbol(MO.getIndex());
+    const MCExpr *Expr =
+        MCSymbolRefExpr::create(Sym, getSpecifier(MO.getTargetFlags()), Ctx);
+    unsigned Flags = MO.getTargetFlags();
+    int64_t Offset = 0;
+    if (Flags == SIInstrInfo::MO_REL32)
+      Offset = 4;
+    else if (Flags == SIInstrInfo::MO_REL32_LO)
+      Offset = 4;
+    else if (Flags == SIInstrInfo::MO_REL32_HI)
+      Offset = 12;
+    if (Offset != 0) {
+      Expr = MCBinaryExpr::createAdd(Expr,
+                                     MCConstantExpr::create(Offset, Ctx), Ctx);
+    }
+    MCOp = MCOperand::createExpr(Expr);
+    return true;
+  }
   case MachineOperand::MO_ExternalSymbol: {
     MCSymbol *Sym = Ctx.getOrCreateSymbol(StringRef(MO.getSymbolName()));
     const MCSymbolRefExpr *Expr = MCSymbolRefExpr::create(Sym, Ctx);
diff -ruN a/llvm/lib/Target/AMDGPU/AMDGPUTargetMachine.cpp b/llvm/lib/Target/AMDGPU/AMDGPUTargetMachine.cpp
