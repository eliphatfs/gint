+#include "llvm/IR/GlobalObject.h"
 
 namespace llvm {
 
+class MachineJumpTableEntry;
+
 class AMDGPUTargetObjectFile : public TargetLoweringObjectFileELF {
   public:
     MCSection *SelectSectionForGlobal(const GlobalObject *GO, SectionKind Kind,
                                       const TargetMachine &TM) const override;
     MCSection *getExplicitSectionGlobal(const GlobalObject *GO, SectionKind Kind,
                                         const TargetMachine &TM) const override;
+    MCSection *getSectionForJumpTable(const Function &F, const TargetMachine &TM,
+                                      const MachineJumpTableEntry *JTE) const override;
+    // Force jump tables through getSectionForJumpTable (which returns .text on
+    // AMDGPU) instead of staying in whatever section happens to be current.
+    // The default keeps label-difference tables in the current section, which
+    // on AMDGPU is .rodata by the time the table is emitted (the kernel
+    // descriptor switches there first). Even with EK_BlockAddress entries the
+    // dispatch's PC-relative base (s_getpc + s_add with a post-getpc label)
+    // computes `JTI - PostGetPC`; if JTI is in .rodata and PostGetPC in .text
+    // the `&4294967295` / `>>32` split of that cross-section difference is not
+    // a relocatable expression the assembler accepts. Keeping the table in
+    // .text makes it same-section.
+    bool shouldPutJumpTableInFunctionSection(bool UsesLabelDifference,
+                                             const Function &F) const override {
+      return false;
+    }
 };
 
 } // end namespace llvm
