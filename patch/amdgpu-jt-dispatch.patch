+++ b/llvm/lib/Target/AMDGPU/AMDGPUTargetMachine.cpp	2026-07-02 17:56:36.751387417 +0000
@@ -1515,6 +1515,13 @@
   }
   addPass(&DeadMachineInstructionElimID);
   addPass(createSIShrinkInstructionsLegacyPass());
+  // Expand SI_BR_JT (jump-table dispatch) here, AFTER EarlyMachineLICM /
+  // MachineLICM have run. S_GETPC_B64 is modeled side-effect-free, so if we
+  // emitted it earlier (right after ISel) LICM would hoist it out of the
+  // dispatch loop, decoupling it from the rel32@lo/+4 fixup that is keyed to
+  // the s_add's own address — which sent s_setpc into the middle of an
+  // unrelated block. Running here keeps s_getpc inside the dispatch block.
+  addPass(createSIExpandJTDispatchPass());
 }
 
